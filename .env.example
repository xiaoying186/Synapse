# SMTP notification credentials.
# Leave empty unless testing guarded email delivery.
SYNAPSE_SMTP_USERNAME=
SYNAPSE_SMTP_PASSWORD=

# Optional local-only notification mock endpoint for guarded webhook tests.
# Delivery attempts are retry-classified and endpoint evidence is redacted.
# Must be an explicit http loopback URL with a port, for example:
# SYNAPSE_MOCK_WEBHOOK_ENDPOINT=http://127.0.0.1:8787/mock-webhook
SYNAPSE_MOCK_WEBHOOK_ENDPOINT=

# Optional staging webhook signature material.
# Leave empty unless running loopback-only webhook staging preflight locally.
SYNAPSE_FEISHU_WEBHOOK_SECRET=
SYNAPSE_WECHAT_WEBHOOK_SECRET=

# Reserved for future relay readiness checks.
# Do not commit real relay tokens.
SYNAPSE_RELAY_TOKEN=
